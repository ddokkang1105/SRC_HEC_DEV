<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" session="false"%><%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %><c:url value="/" var="root"/><c:if test="${! empty resultMap.ALERT_DHX}"><script>if(typeof showDhxAlert === 'undefined' && parent.showDhxAlert) {parent.showDhxAlert("${resultMap.ALERT_DHX}", "confirm", function(){<c:if test="${! empty resultMap.SCRIPT}">${resultMap.SCRIPT};</c:if><c:if test="${! empty resultMap.NEXTPAGE}">if(parent){parent.location.href="${root}${resultMap.NEXTPAGE}";}else{location.href="${root}${resultMap.NEXTPAGE}";}</c:if>});} else {showDhxAlert("${resultMap.ALERT_DHX}", "confirm", function(){<c:if test="${! empty resultMap.SCRIPT}">${resultMap.SCRIPT};</c:if><c:if test="${! empty resultMap.NEXTPAGE}">if(parent){parent.location.href="${root}${resultMap.NEXTPAGE}";}else{location.href="${root}${resultMap.NEXTPAGE}";}</c:if>});}</script></c:if><c:if test="${! empty resultMap.ALERT}"><script>alert("${resultMap.ALERT}");</script></c:if><c:if test="${empty resultMap.ALERT_DHX && ! empty resultMap.SCRIPT}"><script>${resultMap.SCRIPT};</script></c:if><c:if test="${empty resultMap.ALERT_DHX && ! empty resultMap.NEXTPAGE}"><script>if(parent){parent.location.href="${root}${resultMap.NEXTPAGE}";}else{location.href="${root}${resultMap.NEXTPAGE}";}</script></c:if>${resultMap.MESSAGE}